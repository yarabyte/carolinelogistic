# ============================================
# BASE DE DONNÉES Supabase (PostgreSQL)
# ============================================
# Transaction pooler (6543) → runtime Vercel / Next.js
DATABASE_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Session pooler (5432) → migrations Prisma (build Vercel)
DIRECT_URL="postgresql://postgres.[REF]:[PASSWORD]@aws-1-eu-central-1.pooler.supabase.com:5432/postgres"

# ============================================
# VERCEL BLOB (uploads admin / images)
# ============================================
# Créer un Blob store : Vercel → Storage → lier au projet
# En local : copier BLOB_READ_WRITE_TOKEN depuis Vercel → Storage → .env.local
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# ============================================
# AUTH (NextAuth v5)
# ============================================
# Production : https://votre-domaine.vercel.app ou domaine custom
NEXTAUTH_URL="http://localhost:3000"
AUTH_SECRET="generate-with-openssl-rand-base64-32"
# Alias accepté :
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# ============================================
# STRIPE
# ============================================
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ============================================
# EMAIL (SMTP)
# ============================================
SMTP_HOST="mail.example.com"
SMTP_PORT="465"
SMTP_USER="contact@carolinelogistics.fr"
SMTP_PASS="your-smtp-password"
SMTP_FROM="contact@carolinelogistics.fr"

# ============================================
# OPTIONNEL
# ============================================
# NODE_ENV="production"
# DATABASE_POOL_MAX="1"
