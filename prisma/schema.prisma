// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPING
  DELIVERED
  CANCELLED
}

enum PromotionType {
  HOT_DEAL
  WEEKLY
  PRODUCT
  CATEGORY
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model User {
  id            String      @id @default(cuid())
  email         String      @unique
  password      String
  name          String?
  role          UserRole    @default(STAFF)
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  orders        Order[]
  activityLogs  ActivityLog[]

  @@map("users")
}

model Category {
  id            String      @id @default(cuid())
  name          String
  slug          String      @unique
  parentId      String?
  image         String?
  description   String?    @db.Text
  seoTitle      String?
  seoDescription String?   @db.Text
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  parent        Category?   @relation("CategoryToCategory", fields: [parentId], references: [id], onDelete: Cascade)
  children      Category[]  @relation("CategoryToCategory")
  products      Product[]
  promotions    PromotionCategory[]

  @@map("categories")
}

model Partner {
  id              String      @id @default(cuid())
  name            String
  logo            String?
  contact         String?     @db.Text
  commissionRate  Float       @default(0)
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  products        Product[]

  @@map("partners")
}

model Product {
  id              String      @id @default(cuid())
  title           String
  slug            String?     @unique
  description     String?     @db.Text
  price           Float
  dimensions      String?
  weight          Float?
  stock            Int         @default(0)
  tva             Float?       @default(0)
  images          Json         @default("[]")
  categoryId      String?
  isPartner       Boolean      @default(false)
  partnerId       String?
  externalLink    String?
  views           Int          @default(0)
  clicks          Int          @default(0)
  isFeatured      Boolean      @default(false)
  isActive        Boolean      @default(true)
  seoTitle        String?
  seoDescription  String?     @db.Text
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  category        Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  partner         Partner?     @relation(fields: [partnerId], references: [id], onDelete: SetNull)
  orderItems      OrderItem[]
  promotions      PromotionProduct[]

  @@index([categoryId])
  @@index([partnerId])
  @@index([isActive])
  @@index([slug])
  @@map("products")
}

model Promotion {
  id              String      @id @default(cuid())
  type            PromotionType
  name            String
  startDate       DateTime
  endDate         DateTime
  discountType    DiscountType
  discountValue   Float
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  products        PromotionProduct[]
  categories      PromotionCategory[]

  @@map("promotions")
}

model PromotionProduct {
  id            String      @id @default(cuid())
  promotionId  String
  productId    String

  promotion    Promotion   @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([promotionId, productId])
  @@map("promotion_products")
}

model PromotionCategory {
  id            String      @id @default(cuid())
  promotionId  String
  categoryId   String

  promotion    Promotion   @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  category     Category    @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([promotionId, categoryId])
  @@map("promotion_categories")
}

model Order {
  id              String      @id @default(cuid())
  orderNumber     String      @unique
  userId          String?
  status          OrderStatus @default(PENDING)
  total           Float
  shippingCost    Float       @default(0)
  shippingZone    String?
  customerInfo    Json        // { name, email, phone, address }
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user            User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items           OrderItem[]

  @@index([userId])
  @@index([status])
  @@index([orderNumber])
  @@map("orders")
}

model OrderItem {
  id            String      @id @default(cuid())
  orderId      String
  productId    String
  quantity     Int
  price        Float       // Prix au moment de la commande
  createdAt    DateTime    @default(now())

  order        Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product      Product     @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model DeliveryZone {
  id            String      @id @default(cuid())
  name          String
  price         Float
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("delivery_zones")
}

model Newsletter {
  id            String      @id @default(cuid())
  email         String      @unique
  consent       Boolean     @default(false)
  createdAt     DateTime    @default(now())

  @@map("newsletter")
}

model ActivityLog {
  id            String      @id @default(cuid())
  userId        String
  action        String      // CREATE, UPDATE, DELETE, etc.
  entity        String      // Product, Order, Category, etc.
  entityId      String?
  details       Json?       // Additional details
  createdAt     DateTime    @default(now())

  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("activity_logs")
}

model Settings {
  id                String      @id @default(cuid())
  companyName       String?
  logo              String?
  contactEmail      String?
  contactPhone      String?
  address           String?     @db.Text
  defaultTva        Float?      @default(0)
  currency          String?     @default("EUR")
  systemEmail       String?
  facebookUrl       String?
  twitterUrl        String?
  instagramUrl      String?
  linkedinUrl       String?
  tiktokUrl         String?
  defaultBlogImage  String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  @@map("settings")
}

model BlogPost {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  excerpt     String?   @db.Text
  content     String?   @db.Text
  image       String?
  publishedAt DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive])
  @@index([slug])
  @@index([publishedAt])
  @@map("blog_posts")
}

model HeroSlide {
  id          String   @id @default(cuid())
  title       String
  subtitle    String?  @db.Text
  description String?  @db.Text
  image       String
  ctaText     String?
  ctaLink     String?
  badge       String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("hero_slides")
}
